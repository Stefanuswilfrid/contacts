# Supabase: Project Settings → API → Project URL and anon public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only (do NOT use VITE_ — never expose service role to the client).
# Used by: npm run seed:demo-users — creates Auth users and links public.users.auth_user_id
# so DMs use chat_messages (not device-local storage).
# You can set SUPABASE_URL or rely on VITE_SUPABASE_URL (same project as the app).
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# Optional password for seeded demo logins (default DemoDemo11!):
# DEMO_USER_PASSWORD=

# Apply SQL: supabase/migrations/20250219120000_directory_users_and_chat.sql (SQL Editor or CLI).
# Then run seed:demo-users. If linking is "blocked" (duplicate emails in public.users),
# run supabase/sql/dedupe_public_users_by_email.sql then link_public_users_to_auth.sql.
# link_public_users_diagnostics.sql explains each case.
# Enable Realtime on chat_messages if needed: Dashboard → Database → Replication.
